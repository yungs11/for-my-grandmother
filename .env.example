# ─────────────────────────────────────────────
# 🧸 for-grandmother 환경 변수 설정
# 이 파일을 .env로 복사한 후 값을 채워주세요
# cp .env.example .env
# ─────────────────────────────────────────────

# Claude API (필수)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Google Cloud TTS (TTS_PROVIDER=google 사용 시)
GOOGLE_TTS_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# NAVER CLOVA Voice (TTS_PROVIDER=clova 사용 시)
CLOVA_CLIENT_ID=
CLOVA_CLIENT_SECRET=

# Telegram 알림 (보호자 알림)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
